      <aliases enabled='yes' />
      <column caption='Is Multi-Corner?' datatype='integer' name='[Calculation_1232869518524416]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [num_contesting_parties] &gt;= 3 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Is Opposition?' datatype='boolean' name='[Calculation_2157832807641088]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[party] != &apos;PAP&apos;' />
      </column>
      <column caption='Opposition Vote Share' datatype='real' name='[Calculation_2157832807776257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Calculation_2157832807641088] THEN [vote_count] END) / SUM({FIXED [year]: SUM([vote_count])})' />
      </column>
      <column caption='Seat Type' datatype='string' name='[Calculation_2157833317421058]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [num_contesting_parties] = 1 THEN &quot;Uncontested&quot; ELSE &quot;Contested&quot; END' />
      </column>
      <column caption='Seats Won' datatype='integer' name='[Calculation_2157833317507075]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [is_winner] THEN [constituency] END)' />
      </column>
      <column caption='Is Walkover?' datatype='integer' name='[Calculation_2157833326153732]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [num_contesting_parties] = 1 THEN 1 ELSE 0 END' />
      </column>
      <column caption='WP Vote Share Pct' datatype='real' name='[Calculation_2157833482096647]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [party]=&apos;WP&apos; THEN [vote_count] END) / SUM({FIXED [year]: SUM([vote_count])})' />
      </column>
      <column caption='sg_elections_cleaned.csv' datatype='table' name='[__tableau_internal_object_id__].[sg_elections_cleaned.csv_75F7D149D8BA4FDFB220B843D5A5605C]' role='measure' type='quantitative' />
